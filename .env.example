# Merchy's Design Bot - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Recraft AI - Get your key at https://www.recraft.ai/api
RECRAFT_API_KEY=your_recraft_api_key_here

# Asana - Get a Personal Access Token at https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=your_asana_pat_here
ASANA_WORKSPACE_GID=1210933746792503

# Email (Gmail SMTP) - Use an App Password, not your regular password
# Go to Google Account > Security > 2-Step Verification > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=start@merchysmerch.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=Merchy's Design Studio <start@merchysmerch.com>
